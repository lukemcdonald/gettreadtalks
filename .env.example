# Auth
BETTER_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_EMAIL_FROM=noreply@treadtalks.com
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
SITE_URL=http://localhost:3000

# Backend & Database
CONVEX_DEPLOYMENT=dev:your-convex-deployment # For CLI
CONVEX_SITE_URL=https://your-convex-deployment.convex.site # For CLI
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Monitoring & Observability
NEXT_PUBLIC_SENTRY_DEBUG=false
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Security
NEXT_PUBLIC_BOT_PROTECTION_TOKEN=your-bot-protection-token
