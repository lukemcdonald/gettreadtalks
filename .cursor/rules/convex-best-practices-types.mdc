# Convex TypeScript Best Practices

## Requirements

- TypeScript version 5.0.3 or newer
- Use `.ts` extension for Convex functions
- Schema defined for best type support

## Writing Convex Functions

### Use argument validators for automatic type inference

When using argument validation, Convex automatically infers argument types:

```typescript
import { mutation } from "./_generated/server";
import { v } from "convex/values";

export default mutation({
  args: {
    body: v.string(),
    author: v.string(),
  },
  // ✅ Convex automatically infers: {body: string, author: string}
  handler: async (ctx, args) => {
    const { body, author } = args;
    await ctx.db.insert("messages", { body, author });
  },
});
```

### Manual type annotations for internal functions

For internal functions with complex types, annotate manually:

```typescript
import { internalMutation } from "./_generated/server";

export default internalMutation({
  // ✅ Explicitly type arguments for internal functions
  handler: async (ctx, args: { body: string; author: string }) => {
    const { body, author } = args;
    await ctx.db.insert("messages", { body, author });
  },
});
```

## Schema Integration

### Define a schema for full type support

Once you define a schema, database methods are fully typed:

```typescript
import { query } from "./_generated/server";

export const list = query({
  args: {},
  // ✅ Return type is automatically inferred as Promise<Doc<"messages">[]>
  handler: (ctx) => {
    return ctx.db.query("messages").collect();
  },
});
```

### Use generated types

Import types from `_generated/dataModel`:

```typescript
import { Doc, Id } from "./_generated/dataModel";

// ✅ Use Doc for document types
const message: Doc<"messages"> = {
  author: "Alice",
  body: "Hello",
};

// ✅ Use Id for document IDs
const userId: Id<"users"> = "...";
```

## Server-Side Helpers

### Use generated context types

Import context types from `_generated/server`:

```typescript
import { MutationCtx, QueryCtx } from "./_generated/server";
import { Doc, Id } from "./_generated/dataModel";

// ✅ Type helper functions with appropriate context
export async function getUser(ctx: QueryCtx, id: Id<"users">) {
  return await ctx.db.get(id);
}

export async function updateUser(ctx: MutationCtx, id: Id<"users">, data: Partial<Doc<"users">>) {
  await ctx.db.patch(id, data);
}
```

**Note:** `MutationCtx` satisfies the `QueryCtx` interface, so mutation helpers can accept `QueryCtx`.

## Validators and Type Inference

### Reuse validators across schema and arguments

Use `Infer` to get TypeScript types from validators:

```typescript
import { Infer, v } from "convex/values";

// ✅ Define validator once
export const statusValidator = v.union(
  v.literal("draft"),
  v.literal("published"),
  v.literal("archived"),
);

// ✅ Infer TypeScript type from validator
export type Status = Infer<typeof statusValidator>;

// Use in schema, function args, and helpers
export default defineSchema({
  posts: defineTable({
    status: statusValidator,
    title: v.string(),
  }),
});
```

## Document Types Without System Fields

### Use `WithoutSystemFields` for inserts and updates

When creating or updating documents, remove system fields:

```typescript
import { MutationCtx } from "./_generated/server";
import { Doc, Id } from "./_generated/dataModel";
import { WithoutSystemFields } from "convex/server";

// ✅ Insert helper - excludes _id and _creationTime
export async function insertPost(
  ctx: MutationCtx,
  values: WithoutSystemFields<Doc<"posts">>,
) {
  await ctx.db.insert("posts", values);
}
```

## Frontend TypeScript

### Use generated types in React components

Import and use `Doc` and `Id` types in your frontend:

```typescript
import { Doc, Id } from "../convex/_generated/dataModel";

// ✅ Type component props with Doc and Id
function PostView(props: { post: Doc<"posts"> }) {
  // ...
}

function PostList(props: { posts: Doc<"posts">[] }) {
  // ...
}
```

### End-to-end type safety with React hooks

Convex React hooks are fully typed:

```typescript
import { useQuery, useMutation } from "convex/react";
import { api } from "../convex/_generated/api";

function MyComponent() {
  // ✅ Type-safe: messages is Doc<"messages">[] | undefined
  const messages = useQuery(api.messages.list);
  
  // ✅ Type-safe: TypeScript ensures correct argument types
  const sendMessage = useMutation(api.messages.send);
  
  const handleSend = () => {
    // TypeScript will error if arguments don't match
    sendMessage({ body: "Hello", author: "Alice" });
  };
  
  return /* ... */;
}
```

## Inferring Function Return Types

### Use `FunctionReturnType` for query/mutation returns

Infer return types from function references instead of manually declaring:

```typescript
import { FunctionReturnType } from "convex/server";
import { api } from "../convex/_generated/api";

// ✅ Automatically infer return type from backend function
export function MyHelperComponent(props: {
  data: FunctionReturnType<typeof api.myFunctions.getSomething>;
}) {
  // props.data is typed based on what getSomething returns
}

// Example with optional data
export function MyComponent(props: {
  data: FunctionReturnType<typeof api.messages.list> | undefined;
}) {
  if (!data) return <div>Loading...</div>;
  // data is now Doc<"messages">[]
}
```

### Use `UsePaginatedQueryReturnType` for paginated queries

```typescript
import { UsePaginatedQueryReturnType } from "convex/react";
import { api } from "../convex/_generated/api";

// ✅ Type for paginated query results
export function MyPaginationHelperComponent(props: {
  paginatedData: UsePaginatedQueryReturnType<
    typeof api.myFunctions.getSomethingPaginated
  >;
}) {
  const { results, status, loadMore } = props.paginatedData;
  // All properties are properly typed
}
```

## Document IDs and Strings

### Converting strings to document IDs

When receiving IDs as strings (e.g., from URL params), validate and convert:

```typescript
import { Id } from "./_generated/dataModel";

// ✅ Validate ID format before converting
function isValidConvexId(id: string): boolean {
  return /^[a-z0-9]{32}$/.test(id);
}

export const getPost = query({
  args: { id: v.string() },
  handler: async (ctx, { id }) => {
    if (!isValidConvexId(id)) throw new Error("Invalid ID");
    return await ctx.db.get(id as Id<"posts">);
  },
});
```

**Note:** Better to use `v.id("tableName")` validator when possible to avoid string conversion.

## Common Type Patterns

### Sharing custom types between backend and frontend

```typescript
// convex/types.ts
import { Doc } from "./_generated/dataModel";

// ✅ Define shared types in backend
export type PostWithAuthor = {
  author: Doc<"users">;
  post: Doc<"posts">;
};

// components/Post.tsx
import { PostWithAuthor } from "../convex/types";

function PostItem({ data }: { data: PostWithAuthor }) {
  // ✅ Type is shared and consistent
}
```

### Optional and partial types

```typescript
import { Doc } from "./_generated/dataModel";
import { WithoutSystemFields } from "convex/server";

// ✅ Required fields for creation
type NewPost = WithoutSystemFields<Doc<"posts">>;

// ✅ Optional fields for updates
type PostUpdate = Partial<WithoutSystemFields<Doc<"posts">>>;

// ✅ Pick specific fields
type PostPreview = Pick<Doc<"posts">, "_id" | "title" | "author">;

// ✅ Omit specific fields
type PublicPost = Omit<Doc<"posts">, "deletedAt">;
```

