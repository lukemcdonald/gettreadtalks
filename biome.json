{
  "extends": ["ultracite/core", "ultracite/react", "ultracite/next"],
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedImports": "off",
        "noUnusedVariables": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              { "type": true },
              ":BLANK_LINE:",
              "react",
              ["builtin", ":PACKAGE:"],
              ":BLANK_LINE:",
              "@/**",
              "../**",
              "./**"
            ],
            "identifierOrder": "lexicographic"
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["convex/**/*"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!**/*.config.*",
      "!**/*.d.ts",
      "!**/*.tsbuildinfo",
      "!**/.git",
      "!**/.next",
      "!**/.notes",
      "!**/.vercel",
      "!**/build",
      "!**/convex/**/_generated",
      "!**/convex/betterAuth/schema.ts",
      "!**/convex/convex.json",
      "!**/dist",
      "!**/next-env.d.ts",
      "!**/node_modules",
      "!**/pnpm-lock.yaml",
      "!**/src/components/ui"
    ]
  }
}
