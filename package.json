{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "clean": "rm -rf node_modules",
    "db:cleanup:images": "tsx scripts/cleanup-speaker-images.ts",
    "db:cleanup:images:prod": "tsx scripts/cleanup-speaker-images.ts --prod",
    "db:clear": "convex run migration/runMigration:clearAllData",
    "db:clear:prod": "convex run migration/runMigration:clearAllData --prod",
    "db:seed": "tsx scripts/run-seed.ts",
    "db:seed:prod": "tsx scripts/run-seed.ts --prod",
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:open",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --experimental-https",
    "dev:open": "wait-on https://localhost:3000 && open https://localhost:3000",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "format:fix:yolo": "pnpm biome check --write --unsafe .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "release": "convex deploy --yes",
    "release:full": "pnpm build && pnpm release",
    "start": "next start",
    "style": "biome check --write",
    "typecheck": "tsc --noEmit",
    "update:ui": "pnpm dlx shadcn@latest add @coss/ui --overwrite",
    "update:ui:styles": "pnpm dlx shadcn@latest add @coss/colors-neutral --overwrite"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@convex-dev/better-auth": "0.10.10",
    "@convex-dev/resend": "^0.2.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.4",
    "@react-email/render": "^2.0.2",
    "@sentry/nextjs": "^10.34.0",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.5",
    "convex-helpers": "^0.1.111",
    "js-sha256": "^0.11.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.71.1",
    "react-lite-youtube-embed": "^3.3.3",
    "resend": "^6.7.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.3",
    "next-devtools-mcp": "^0.3.10",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.0.11",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
