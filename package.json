{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "deploy": "convex deploy --cmd \"npm run build\"",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --turbopack",
    "format": "prettier ./app ./components ./convex ./lib",
    "format:fix": "prettier ./app ./components ./convex ./lib --write --ignore-unknown",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "predev": "convex dev --until-success && convex dashboard && sleep 2 && open http://localhost:3000",
    "start": "next start",
    "style": "npm run lint:fix && npm run format:fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.8.9",
    "@sentry/nextjs": "^10.17.0",
    "better-auth": "^1.3.27",
    "convex": "^1.27.4",
    "next": "15.5.4",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-perfectionist": "^4.15.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  }
}
