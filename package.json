{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build:next",
    "build:convex": "npm run build:next && convex deploy --yes",
    "build:next": "next build",
    "build:webpack": "next build --webpack",
    "check": "biome check .",
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:open",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --experimental-https",
    "dev:open": "wait-on https://localhost:3000 && open https://localhost:3000",
    "dev:webpack": "next dev --experimental-https --webpack",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "push": "convex deploy --yes",
    "seed": "convex run seed:seed",
    "seed:force": "convex run seed:seed '{\"force\": true}'",
    "start": "next start",
    "style": "biome check --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.4",
    "@convex-dev/better-auth": "^0.9.7",
    "@convex-dev/resend": "^0.1.13",
    "@react-email/components": "^1.0.0",
    "@react-email/render": "^2.0.0",
    "@sentry/nextjs": "^10.23.0",
    "better-auth": "^1.3.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.28.2",
    "convex-helpers": "^0.1.104",
    "js-sha256": "^0.11.1",
    "lucide-react": "^0.553.0",
    "next": "16.0.1",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "resend": "^6.4.2",
    "tailwind-merge": "^3.3.1",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@faker-js/faker": "^10.1.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "next-devtools-mcp": "^0.3.1",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "6.3.2",
    "wait-on": "^9.0.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
