{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "convex deploy --cmd 'npm run build:next'",
    "build:next": "next build",
    "check": "biome check .",
    "dev": "npm-run-all --parallel dev:frontend dev:backend dev:open",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --turbopack",
    "dev:open": "wait-on http://localhost:3000 && open http://localhost:3000",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "push": "convex deploy --yes",
    "seed": "convex run seed:seed",
    "seed:force": "convex run seed:seed '{\"force\": true}'",
    "start": "next start",
    "style": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.9.5",
    "@convex-dev/resend": "^0.1.13",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@sentry/nextjs": "^10.19.0",
    "better-auth": "^1.3.27",
    "convex": "^1.27.5",
    "convex-helpers": "^0.1.104",
    "next": "15.5.5",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "resend": "^6.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@faker-js/faker": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.1"
  }
}
