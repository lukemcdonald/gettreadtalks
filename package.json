{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "npm-run-all --parallel dev:frontend dev:backend dev:open",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --turbopack",
    "dev:open": "wait-on http://localhost:3000 && open http://localhost:3000",
    "format": "prettier ./app ./components ./convex ./lib",
    "format:fix": "prettier ./app ./components ./convex ./lib --write --ignore-unknown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "push": "convex deploy --yes",
    "push:prod": "convex deploy --cmd \"npm run build\"",
    "seed": "convex run seed:seed",
    "seed:force": "convex run seed:seed '{\"force\": true}'",
    "start": "next start",
    "style": "npm run lint:fix && npm run format:fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.9.5",
    "@sentry/nextjs": "^10.19.0",
    "better-auth": "^1.3.27",
    "convex": "^1.27.5",
    "convex-helpers": "^0.1.104",
    "next": "15.5.5",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@faker-js/faker": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.5",
    "eslint-plugin-perfectionist": "^4.15.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.1"
  }
}
