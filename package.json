{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "clean": "rm -rf node_modules",
    "db:clear": "convex run migration/runMigration:clearAllData",
    "db:clear:prod": "convex run migration/runMigration:clearAllData --prod",
    "db:seed": "tsx scripts/run-seed.ts",
    "db:seed:prod": "tsx scripts/run-seed.ts --prod",
    "deploy": "next build && convex deploy --yes",
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:open",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --experimental-https",
    "dev:open": "wait-on https://localhost:3000 && open https://localhost:3000",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "start": "next start",
    "style": "biome check --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.4",
    "@convex-dev/better-auth": "^0.9.7",
    "@convex-dev/resend": "^0.1.13",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@sentry/nextjs": "^10.29.0",
    "better-auth": "1.3.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.29.3",
    "convex-helpers": "^0.1.106",
    "js-sha256": "^0.11.1",
    "lucide-react": "^0.555.0",
    "next": "16.0.7",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "resend": "^6.5.2",
    "tailwind-merge": "^3.4.0",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.2.3",
    "next-devtools-mcp": "^0.3.6",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "6.3.6",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
