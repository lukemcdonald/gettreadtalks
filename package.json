{
  "name": "treadtalks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "deploy": "convex deploy --cmd \"npm run build\"",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --turbopack",
    "format": "prettier ./src",
    "format:fix": "prettier ./src --write --ignore-unknown",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "predev": "convex dev --until-success && convex dashboard && sleep 2 && open http://localhost:3000",
    "start": "next start",
    "style": "npm run lint:fix && npm run format:fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.8.6",
    "@sentry/nextjs": "^10.15.0",
    "better-auth": "^1.3.8",
    "convex": "^1.27.3",
    "next": "15.5.4",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-perfectionist": "^4.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
